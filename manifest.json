{
  "manifest_version": 3,
  "name": "LUPX Bookmark",
  "version": "0.1.0",
  "description": "New Tab bookmark grid with 9 card styles, groups, drag-and-drop, and custom backgrounds.",
  "permissions": ["history", "storage", "favicon"],
  "chrome_url_overrides": {
    "newtab": "src/newtab/newtab.html"
  },
  "icons": {
    "16": "icons/lupx_logo.png",
    "48": "icons/lupx_logo.png",
    "128": "icons/lupx_logo.png"
  }
}
